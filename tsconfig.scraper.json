{
  "compilerOptions": {
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "target": "es2020",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/scrapers/**/*.ts", "src/lib/**/*.ts"],
  "exclude": ["node_modules"]
}
